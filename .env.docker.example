# Shared database URL for services running in Docker network
DATABASE_URL=postgresql://postgres:mypassword@postgres:5432/postgres

# Frontend (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Backend auth (Clerk/JWT public key)
# Keep literal \n and middleware will convert to real newlines.
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_REAL_KEY\n-----END PUBLIC KEY-----

# Worker model API key
GOOGLE_API_KEY=replace_me
